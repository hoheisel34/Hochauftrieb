<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="riscv-venus" Version="1.7.0" Publisher="hm"  />
    <DisplayName>RISC-V Venus Simulator</DisplayName>
    <Description xml:space="preserve">RISC-V Venus Simulator embedded in VS Code</Description>
    <Tags>multi-root ready,debuggers,riscv,RISC-V,__ext_s,__ext_S</Tags>
    <Categories>Debuggers</Categories>
    <GalleryFlags>Public</GalleryFlags>
    <Badges></Badges>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Code.Engine" Value="^1.48.0" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionDependencies" Value="" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionPack" Value="" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionKind" Value="workspace" />
      <Property Id="Microsoft.VisualStudio.Code.LocalizedLanguages" Value="" />
      
        <Property Id="Microsoft.VisualStudio.Services.Links.Source" Value="https://github.com/hm-riscv/vscode-riscv-venus" />
        <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/hm-riscv/vscode-riscv-venus" />
        
          <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/hm-riscv/vscode-riscv-venus" />
        
      
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/hm-riscv/vscode-riscv-venus/issues" />
      
      
      
      <Property Id="Microsoft.VisualStudio.Services.GitHubFlavoredMarkdown" Value="true" />
      
      
      
    </Properties>
    
    <Icon>extension/images/riscv-venus-icon.png</Icon>
  </Metadata>
  <Installation>
